import java.util.Scanner;
class  Factorial2
{
	public static void main(String[] args) 
	{
		Scanner sc = new Scanner(System.in);
		System.out.println("Enter a NO : ");
		int num = sc.nextInt();
		int num1 = num;
		int mul=1;
		
		
		for (int i =1 ; i <=num ;i-- )
		{
			mul=mul*i;
		}
		
		System.out.println("Factorial of a "+num1+" = "+mul);
		
	}
}