package Switch;
import java.util.Scanner;

public class Corpregins {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        System.out.println("Enter the region of India:");
        String region =sc.nextLine();
        
        switch (region) {
            case "North":System.out.println("Wheat, Rice, Sugarcane, Mustard");
                
                break;

            case "South":System.out.println(" Rice, Coffee, Coconut, Spices");
                break;

            case "East":System.out.println("Rice, Jute, Tea, Sugarcane");
                break;

            case "West":System.out.println(" Cotton, Groundnut, Bajra, Sugarcane");
                break;
        
            default:System.out.println("Invalid Input");
                break;
        }


    }
}
