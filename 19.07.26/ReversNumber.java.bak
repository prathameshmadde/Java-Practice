import java.util.Scanner;

class  ReversNumber
{
	public static void main(String[] args) 
	{
		Scanner sc = new Scanner(System.in);
		System.out.println("Enter a number : ");
		int num = sc.nextInt();
		int ans = 0; 
		
		while (num>0)
		{	
			int last = num%10;
			ans = ans *10 + last;
			num/=10;
		}
		System.out.println(" Reverse Number = " + ans);
		
		
	}
}
