import java.util.Scanner;
class  OneEven
{
	public static void main(String[] args) 
	{	Scanner sc = new Scanner(System.in);
		System.out.println("Enter a Number : ");
		
		int num =sc.nextInt();
		int count=0;
		while (num!=0)
		{	
			int last = num%10;
			if(last %2 == 0)
			{
				count++;
			}
			num/=10;
		}
		
		if(count==1)	{
			System.out.println("It contain only one digit .");
		}
		else if(count==0){
			System.out.println("It dosent cntain any even digit no .");
			
		}
		else {
			System.out.println("It contain more than one even digit no .");
		}
		
	}
}
